# Qwen Cloud API
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen2.5-72b-instruct
QWEN_TIMEOUT_SECONDS=60

# Database
DATABASE_URL=postgresql+asyncpg://qwen:qwen_council@db:5432/qwen_council
POSTGRES_USER=qwen
POSTGRES_PASSWORD=qwen_council
POSTGRES_DB=qwen_council

# App
APP_ENV=development
LOG_LEVEL=INFO
