# Qwen Cloud API — REQUIRED: Get your key from https://modelstudio.console.alibabacloud.com/
qwen_api_key=sk-your-qwen-api-key-here
qwen_model=qwen-plus
qwen_base_url=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
qwen_embedding_model=text-embedding-v3
qwen_timeout_seconds=300

# Database — defaults for docker-compose (postgres on host 'db')
database_url=postgresql+asyncpg://qwen:qwen_council@db:5432/qwen_council
database_echo=false

# Server
host=0.0.0.0
port=8000
cors_origins=["*"]
