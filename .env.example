# LLM Provider (OpenAI-compatible) — REQUIRED
# Get your Qwen key from https://modelstudio.console.alibabacloud.com/
# Or use any OpenAI-compatible API (OpenAI, Ollama, vLLM, LM Studio)
llm_api_key=sk-your-api-key-here
llm_model=qwen3-coder-plus-2025-09-23  # or qwen-plus-latest, qwen3-coder-plus, etc.
llm_base_url=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
llm_embedding_model=text-embedding-v3
llm_timeout_seconds=300
llm_provider=qwen  # qwen | openai | ollama

# Database — defaults for docker-compose (postgres on host 'db')
database_url=postgresql+asyncpg://multiagent:multiagent_council@db:5432/multiagent_council
database_echo=false

# Server
host=0.0.0.0
port=8000
cors_origins=["*"]
